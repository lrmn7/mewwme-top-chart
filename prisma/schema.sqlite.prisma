// Prisma schema for SQLite
// To use: set DATABASE_URL to file:./dev.db in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ArtistSnapshot {
  id               String   @id @default(cuid())
  artistName       String
  country          String   @default("global")
  rank             Int
  monthlyListeners Int
  listenersDelta   Int?
  createdAt        DateTime @default(now())
  
  @@index([createdAt])
  @@index([artistName])
  @@index([country])
}

model ArtistCurrent {
  id               String   @id @default(cuid())
  artistId         String?  // Spotify ID if matched
  artistName       String
  country          String   @default("global") // "global" or country code like "id"
  rank             Int
  previousRank     Int?
  rankDelta        Int?     // negative = moved up, positive = moved down
  monthlyListeners Int
  listenersDelta   Int?
  imageUrl         String?
  genres           String?  // JSON array as string
  spotifyUrl       String?
  
  // Enhanced metadata for About section
  followers        Int?     // Spotify followers count
  popularity       Int?     // Spotify popularity score (0-100)
  images           String?  // JSON array of image URLs with different sizes
  biography        String?  // Artist biography from Wikipedia
  socialLinks      String?  // JSON object {facebook, instagram, twitter}
  originCountry    String?  // Artist's country of origin
  countryCode      String?  // ISO 3166-1 alpha-2 country code for flag
  birthDate        String?  // Artist's birth date
  
  // Last.fm Data
  topTracks        String?  // JSON array of top tracks
  topAlbums        String?  // JSON array of top albums
  similarArtists   String?  // JSON array of similar artists

  peakRank         Int?
  peakRankDate     DateTime?
  firstSeenDate    DateTime?

  lastUpdated      DateTime @default(now()) @updatedAt
  
  @@unique([artistName, country])
  @@index([rank])
  @@index([artistName])
  @@index([country])
}

model BlogPost {
  id        String   @id @default(cuid())
  date      DateTime @unique // One post per day
  headline  String
  content   String   // JSON string of the DailyBriefing object
  createdAt DateTime @default(now())
  
  @@index([date])
}

model TrackSnapshot {
  id           String   @id @default(cuid())
  trackName    String
  artistName   String
  country      String   @default("global")
  rank         Int
  dailyStreams  BigInt
  totalStreams  BigInt?
  createdAt    DateTime @default(now())
  
  @@index([createdAt])
  @@index([trackName, artistName])
  @@index([country])
}

model TrackCurrent {
  id           String   @id @default(cuid())
  trackId      String?  // Spotify ID if matched
  trackName    String
  artistName   String
  country      String   @default("global") // "global" or country code like "id"
  rank         Int
  previousRank Int?
  rankDelta    Int?     // negative = moved up, positive = moved down
  dailyStreams  BigInt
  totalStreams  BigInt?
  imageUrl     String?
  previewUrl   String?
  spotifyUrl   String?
  lastUpdated  DateTime @default(now()) @updatedAt
  
  @@unique([trackName, artistName, country])
  @@index([rank])
  @@index([trackName, artistName])
  @@index([country])
}
